# torus.fm reverse proxy with auto-HTTPS via Let's Encrypt
#
# Substitutes $DOMAIN and $LETSENCRYPT_EMAIL from env vars in docker-compose.prod.yml
#
# Routes:
#   torus.fm           -> web app
#   *.torus.fm         -> web app (wildcard for supporter custom subdomains)
#   media.torus.fm     -> MinIO bucket (audio + waveform image serving)

{
	email {$LETSENCRYPT_EMAIL}
	# Uncomment for staging certs while testing:
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
	servers {
		protocols h1 h2 h3
	}
}

# Main app + supporter custom subdomains
{$DOMAIN}, *.{$DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	reverse_proxy web:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# MinIO bucket — serves uploaded audio + waveform images
media.{$DOMAIN} {
	encode zstd gzip

	# Aggressive long cache for immutable storage objects (keyed by content hash)
	header /torus-clips/* Cache-Control "public, max-age=31536000, immutable"
	header /torus-clips/* Access-Control-Allow-Origin "*"

	reverse_proxy minio:9000
}
