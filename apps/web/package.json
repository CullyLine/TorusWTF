{
  "name": "@torus/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,worker -c blue,magenta \"next dev --port 3000\" \"pnpm --filter @torus/worker dev\"",
    "dev:web-only": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "clean": "rimraf .next .turbo .tsbuildinfo"
  },
  "dependencies": {
    "@torus/db": "workspace:*",
    "@torus/shared": "workspace:*",
    "@torus/storage": "workspace:*",
    "@torus/ui": "workspace:*",
    "@torus/visualizers": "workspace:*",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "arctic": "^3.6.0",
    "better-sqlite3": "^11.7.0",
    "bullmq": "^5.34.6",
    "dotenv": "^17.0.0",
    "drizzle-orm": "^0.38.3",
    "framer-motion": "^11.15.0",
    "ioredis": "^5.4.2",
    "next": "15.5.18",
    "nodemailer": "^6.9.16",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-dropzone": "^14.3.5",
    "wavesurfer.js": "^7.9.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.0.0-beta.8",
    "@types/better-sqlite3": "^7.6.12",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.18",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0-beta.8",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
