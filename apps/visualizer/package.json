{
  "name": "@torus/visualizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-conductor-assets.mjs && node scripts/copy-transcriber-assets.mjs && next dev --port 3000",
    "prefetch:conductor": "node scripts/copy-conductor-assets.mjs",
    "prefetch:transcriber": "node scripts/copy-transcriber-assets.mjs",
    "build": "pnpm prefetch:conductor && pnpm prefetch:transcriber && next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf .next .turbo .tsbuildinfo"
  },
  "dependencies": {
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@spotify/basic-pitch": "^1.0.1",
    "@tonejs/midi": "^2.0.28",
    "@torus/db": "workspace:*",
    "@torus/shared": "workspace:*",
    "@torus/ui": "workspace:*",
    "@torus/visualizers": "workspace:*",
    "arctic": "^3.6.0",
    "dotenv": "^17.0.0",
    "drizzle-orm": "^0.38.3",
    "fft.js": "^4.0.4",
    "mp4-muxer": "^5.2.2",
    "next": "15.5.18",
    "nodemailer": "^6.9.16",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "spessasynth_core": "^4.3.7",
    "spessasynth_lib": "^4.3.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.8",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0-beta.8",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
