{
  "name": "@torus/visualizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-conductor-assets.mjs && next dev --port 3001",
    "prefetch:demos": "node scripts/fetch-demos.mjs",
    "prefetch:conductor": "node scripts/copy-conductor-assets.mjs",
    "build": "pnpm prefetch:demos && pnpm prefetch:conductor && next build",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf .next .turbo .tsbuildinfo"
  },
  "dependencies": {
    "@torus/shared": "workspace:*",
    "@torus/ui": "workspace:*",
    "@torus/visualizers": "workspace:*",
    "dotenv": "^17.0.0",
    "fft.js": "^4.0.4",
    "mp4-muxer": "^5.2.2",
    "next": "15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "soundcloud-downloader": "github:zackradisic/node-soundcloud-downloader",
    "spessasynth_core": "^4.3.7",
    "spessasynth_lib": "^4.3.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.8",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0-beta.8",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
