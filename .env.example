# torus — environment
# Copy to .env and fill in. Everything except the database has a sane default,
# and every integration below is optional: the app runs without auth, email,
# or payments configured.

# ---- App ----
NODE_ENV=development
# Public base URL — used for OAuth redirects, magic links, and checkout return.
PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Database (libSQL / Turso) ----
# Local dev: an on-disk SQLite file. Production: a Turso URL + auth token.
# The URL and its token must come from the SAME database, or Turso returns 401:
#   - DATABASE_URL  pairs with  DATABASE_AUTH_TOKEN
#   - TURSO_DATABASE_URL  pairs with  TURSO_AUTH_TOKEN
DATABASE_URL=file:./data/torus.db
DATABASE_AUTH_TOKEN=
# The Vercel Turso integration injects TURSO_DATABASE_URL + TURSO_AUTH_TOKEN as a
# matched pair (used when DATABASE_URL is unset). If you ALSO hand-set
# DATABASE_URL on Vercel, give it DATABASE_AUTH_TOKEN so the integration's
# TURSO_AUTH_TOKEN (scoped to a different/branch DB) can't be paired with it.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# ---- Email / magic-link sign-in (optional) ----
# Local dev: run Mailhog (or any catcher) on :1025 and read mail at :8025.
# Production: a real SMTP provider (Resend, SendGrid, etc.) on 587 + SMTP_SECURE=true.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="torus <noreply@torus.wtf>"
SMTP_SECURE=false
MAILHOG_WEB_URL=http://localhost:8025

# ---- Discord OAuth (optional) ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---- Production License — Polar.sh (optional) ----
# POLAR_API_KEY + POLAR_PRODUCTION_LICENSE_PRODUCT_ID enable one-time checkout.
# POLAR_WEBHOOK_SECRET verifies the order webhook that grants the license.
POLAR_API_KEY=
POLAR_PRODUCTION_LICENSE_PRODUCT_ID=0241a247-4502-4919-b985-abae0ea49e1e
POLAR_WEBHOOK_SECRET=
# Optional: override the Polar API base (defaults to https://api.polar.sh).
POLAR_API_BASE=
