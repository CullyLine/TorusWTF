# ---- Web app ----
NODE_ENV=development
PUBLIC_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ---- Database ----
DATABASE_URL=file:./data/torus.db

# ---- Redis (BullMQ + rate limiting) ----
REDIS_URL=redis://localhost:6379

# ---- Storage ----
# Pick one driver. Local dev uses MinIO via docker-compose.
STORAGE_DRIVER=minio
STORAGE_BUCKET=torus-clips
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
# Public URL where uploaded clips can be fetched from (Caddy-proxied in prod)
STORAGE_PUBLIC_URL=http://localhost:9000/torus-clips

# ---- Upload limits ----
# Any *_PER_HOUR / *_PER_DAY value of 0 disables that limit entirely.
UPLOAD_MAX_BYTES=209715200          # 200 MB
UPLOAD_MAX_DURATION_MS=1800000      # 30 min
UPLOAD_ANON_PER_HOUR=5
UPLOAD_ANON_PER_DAY=20
UPLOAD_USER_PER_DAY=50
UPLOAD_USER_QUOTA_BYTES=5368709120  # 5 GB
EMERGENCY_STOP=false

# ---- Email (any SMTP) ----
# Local dev: Mailhog captures mail — open http://localhost:8025 (not your real inbox).
# Production: use a real provider (Resend, SendGrid, etc.) on port 587 with SMTP_SECURE=true.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="torus.wtf <noreply@torus.wtf>"
SMTP_SECURE=false
MAILHOG_WEB_URL=http://localhost:8025

# ---- Discord OAuth (optional) ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---- Payments — Polar.sh (optional) ----
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=
# Credit-pack product ids — create 3 one-time products in Polar and paste ids:
#   Starter ($5 / 500 cr), Plus ($20 / 2000 cr), Pro ($50 / 5000 cr)
POLAR_CREDITS_PRODUCT_STARTER=
POLAR_CREDITS_PRODUCT_PLUS=
POLAR_CREDITS_PRODUCT_PRO=

# ---- Lab / GPU compute (credits economy) ----
# Serverless GPU provider for stem separation (get a token at replicate.com).
REPLICATE_API_TOKEN=
# Compute backend: "replicate" now; "home3090" once the self-hosted GPU is up.
COMPUTE_PROVIDER=replicate
# Hours to keep Lab inputs/outputs before the worker auto-deletes them.
LAB_RETENTION_HOURS=24
# Public URL of the web app — used for cross-app links + signed/OpenAPI URLs.
NEXT_PUBLIC_TORUS_WEB_URL=http://localhost:3000

# ---- Observability (optional, disabled by default) ----
SENTRY_DSN=
HEALTH_WEBHOOK_URL=
