# ---- Web app ----
NODE_ENV=development
PUBLIC_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ---- Database ----
DATABASE_URL=file:./data/torus.db

# ---- Redis (BullMQ + rate limiting) ----
REDIS_URL=redis://localhost:6379

# ---- Storage ----
# Pick one driver. Local dev uses MinIO via docker-compose.
STORAGE_DRIVER=minio
STORAGE_BUCKET=torus-clips
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
# Public URL where uploaded clips can be fetched from (Caddy-proxied in prod)
STORAGE_PUBLIC_URL=http://localhost:9000/torus-clips

# ---- Upload limits ----
# Any *_PER_HOUR / *_PER_DAY value of 0 disables that limit entirely.
UPLOAD_MAX_BYTES=209715200          # 200 MB
UPLOAD_MAX_DURATION_MS=1800000      # 30 min
UPLOAD_ANON_PER_HOUR=5
UPLOAD_ANON_PER_DAY=20
UPLOAD_USER_PER_DAY=50
UPLOAD_USER_QUOTA_BYTES=5368709120  # 5 GB
EMERGENCY_STOP=false

# ---- Email (any SMTP) ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="torus.fm <noreply@torus.fm>"
SMTP_SECURE=false

# ---- Discord OAuth (optional) ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---- Payments — Polar.sh (optional) ----
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=

# ---- Observability (optional, disabled by default) ----
SENTRY_DSN=
HEALTH_WEBHOOK_URL=
